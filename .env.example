# Optional: direct EIA API v2 refresh. The public fallback uses EIA series via FRED.
# Free key: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# Optional: exact NYMEX WTI front-month settlement series (CHRIS/CME_CL1).
# Without this key, the dashboard explicitly labels WTI spot as a proxy.
NASDAQ_DATA_LINK_API_KEY=

# Preferred generic server-side AIS gateway returning the normalized contract in docs/API.md.
TANKER_API_URL=
TANKER_API_KEY=

# Optional direct Datalastic adapter. Both fields are required to opt in because
# area scans consume provider credits. Supply 1-5 areas; radius is nautical miles.
DATALASTIC_API_KEY=
DATALASTIC_LOCATIONS_JSON=[{"lat":26.55,"lon":56.25,"radius":25}]

# Optional JSON polling feed matching the contract in docs/API.md. Include an
# ISO-8601 asOf timestamp; data older than 14 days is labeled degraded.
POLLING_API_URL=
